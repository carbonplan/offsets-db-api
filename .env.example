# offsets-db-api environment variables
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection URL.
# Default below matches the docker-compose.yml service (docker compose up -d db).
# If you prefer a local Postgres managed by pixi, run:
#   pixi run db-init   # one-time setup
#   pixi run db-start  # start the server
# and use: postgresql://offsets_db:offsets_db@localhost:5432/offsets_db
OFFSETS_DB_DATABASE_URL=postgresql://offsets_db:offsets_db@localhost:5432/offsets_db

# ── API ───────────────────────────────────────────────────────────────────────
# Secret key required for protected write endpoints (POST /files, etc.).
# Any non-empty string works locally; must match X-API-Key header in requests.
OFFSETS_DB_API_KEY=local-dev-key

# ── Environment flags ────────────────────────────────────────────────────────
# Set to true to enable staging mode (relaxed validation, verbose errors).
OFFSETS_DB_STAGING=true

# Number of Gunicorn/Uvicorn workers. Keep at 1 for local dev.
OFFSETS_DB_WEB_CONCURRENCY=1

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
# Use * to allow all origins (default; fine for local dev).
# In production, set this to the frontend domain, e.g.:
#   OFFSETS_DB_ALLOWED_ORIGINS=https://carbonplan.org,https://offsets.carbonplan.org
OFFSETS_DB_ALLOWED_ORIGINS=*
